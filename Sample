<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>💊 PharmaPlus - Your Health Store</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background: #f5f5f5;
            min-height: 100vh;
            position: relative;
            color: #333;
        }

        /* Animated Background - Light Green */
        .animated-bg {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(-45deg, #e8f5e9, #c8e6c9, #a5d6a7, #81c784);
            background-size: 400% 400%;
            animation: gradient 15s ease infinite;
            z-index: -1;
        }

        @keyframes gradient {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        /* Header */
        header {
            background: white;
            padding: 15px 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 2px 20px rgba(0,100,0,0.1);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .logo h1 {
            font-size: 24px;
            color: #2e7d32;
            font-weight: 600;
        }

        /* Search Container */
        .search-container {
            background: #f1f8e9;
            padding: 8px 20px;
            border-radius: 40px;
            width: 350px;
            display: flex;
            align-items: center;
            border: 2px solid #81c784;
            transition: all 0.3s ease;
        }

        .search-container:focus-within {
            border-color: #2e7d32;
            box-shadow: 0 0 15px rgba(46, 125, 50, 0.3);
            transform: scale(1.02);
        }

        .search-icon {
            color: #2e7d32;
            margin-right: 10px;
            font-size: 16px;
        }

        .search-input {
            border: none;
            outline: none;
            width: 100%;
            font-size: 15px;
            background: transparent;
            color: #333;
        }

        .search-input::placeholder {
            color: #689f38;
            font-style: italic;
        }

        /* Small Cart Icon */
        .cart-icon-container {
            position: relative;
            cursor: pointer;
            padding: 10px;
            border-radius: 50%;
            background: #e8f5e9;
            transition: all 0.3s ease;
        }

        .cart-icon-container:hover {
            background: #c8e6c9;
            transform: scale(1.1);
        }

        .cart-icon-container i {
            font-size: 24px;
            color: #2e7d32;
        }

        .cart-badge {
            position: absolute;
            top: -5px;
            right: -5px;
            background: #d32f2f;
            color: white;
            font-size: 12px;
            font-weight: bold;
            width: 20px;
            height: 20px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            animation: bounce 2s infinite;
        }

        @keyframes bounce {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.2); }
        }

        /* Main Container */
        .container {
            max-width: 1200px;
            margin: 30px auto;
            padding: 0 20px;
        }

        .section-title {
            text-align: center;
            color: #2e7d32;
            margin-bottom: 30px;
            font-size: 32px;
            text-shadow: 1px 1px 2px rgba(0,0,0,0.1);
            background: rgba(255,255,255,0.8);
            padding: 15px;
            border-radius: 50px;
            display: inline-block;
            width: auto;
            margin-left: auto;
            margin-right: auto;
            box-shadow: 0 5px 15px rgba(46, 125, 50, 0.2);
        }

        /* Products Grid */
        .products-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 25px;
            padding: 20px;
        }

        /* Product Card */
        .product-card {
            background: white;
            border-radius: 15px;
            padding: 20px;
            text-align: center;
            box-shadow: 0 10px 30px rgba(46, 125, 50, 0.1);
            transition: all 0.3s ease;
            cursor: pointer;
            animation: fadeInUp 0.5s ease;
            border: 1px solid #c8e6c9;
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .product-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(46, 125, 50, 0.2);
            border-color: #81c784;
        }

        .product-card img {
            width: 150px;
            height: 150px;
            object-fit: cover;
            border-radius: 10px;
            margin-bottom: 15px;
            border: 3px solid #c8e6c9;
        }

        .product-card h3 {
            color: #2e7d32;
            margin-bottom: 10px;
            font-size: 18px;
            font-weight: 600;
        }

        .price {
            font-size: 24px;
            font-weight: bold;
            color: #2e7d32;
            margin-bottom: 15px;
        }

        .add-to-cart-btn {
            background: linear-gradient(135deg, #4caf50, #2e7d32);
            color: white;
            border: none;
            padding: 12px 20px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 14px;
            font-weight: 500;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            width: 100%;
            transition: all 0.3s ease;
        }

        .add-to-cart-btn:hover {
            background: linear-gradient(135deg, #66bb6a, #388e3c);
            transform: scale(1.05);
            box-shadow: 0 5px 15px rgba(46, 125, 50, 0.4);
        }

        /* Cart Sidebar */
        .cart-sidebar {
            position: fixed;
            top: 0;
            right: -400px;
            width: 380px;
            height: 100vh;
            background: white;
            box-shadow: -5px 0 30px rgba(46, 125, 50, 0.2);
            transition: right 0.3s ease;
            z-index: 1000;
            display: flex;
            flex-direction: column;
        }

        .cart-sidebar.open {
            right: 0;
        }

        .cart-header {
            padding: 20px;
            border-bottom: 1px solid #c8e6c9;
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: linear-gradient(135deg, #4caf50, #2e7d32);
            color: white;
        }

        .cart-header h3 {
            font-size: 18px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .close-cart {
            background: none;
            border: none;
            color: white;
            font-size: 20px;
            cursor: pointer;
            transition: transform 0.3s ease;
        }

        .close-cart:hover {
            transform: rotate(90deg);
        }

        .cart-items {
            flex: 1;
            overflow-y: auto;
            padding: 20px;
        }

        /* Cart Item */
        .cart-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px;
            border-bottom: 1px solid #c8e6c9;
            animation: slideIn 0.3s ease;
        }

        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateX(20px);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        .cart-item-info {
            flex: 1;
        }

        .cart-item-name {
            font-weight: 600;
            color: #2e7d32;
            margin-bottom: 5px;
        }

        .cart-item-price {
            color: #4caf50;
            font-size: 14px;
        }

        .cart-item-actions {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .quantity-btn {
            background: #e8f5e9;
            border: none;
            width: 30px;
            height: 30px;
            border-radius: 5px;
            cursor: pointer;
            font-weight: bold;
            color: #2e7d32;
            transition: all 0.3s ease;
        }

        .quantity-btn:hover {
            background: #4caf50;
            color: white;
        }

        .item-quantity {
            font-weight: 600;
            min-width: 30px;
            text-align: center;
            color: #2e7d32;
        }

        .remove-item {
            background: none;
            border: none;
            color: #d32f2f;
            cursor: pointer;
            font-size: 16px;
            transition: transform 0.3s ease;
        }

        .remove-item:hover {
            transform: scale(1.2);
        }

        /* Cart Footer */
        .cart-footer {
            padding: 20px;
            border-top: 2px solid #c8e6c9;
            background: #f9f9f9;
        }

        .cart-total {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
            font-size: 18px;
            font-weight: 600;
        }

        .total-amount {
            color: #2e7d32;
            font-size: 24px;
        }

        .checkout-btn {
            width: 100%;
            padding: 15px;
            background: linear-gradient(135deg, #25D366, #128C7E);
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            transition: all 0.3s ease;
        }

        .checkout-btn:hover {
            transform: scale(1.02);
            box-shadow: 0 5px 20px rgba(37, 211, 102, 0.4);
        }

        /* Overlay */
        .overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(46, 125, 50, 0.2);
            backdrop-filter: blur(3px);
            z-index: 999;
            display: none;
        }

        .overlay.show {
            display: block;
        }

        /* Toast Notification */
        .toast {
            position: fixed;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%);
            background: #2e7d32;
            color: white;
            padding: 12px 25px;
            border-radius: 50px;
            font-size: 14px;
            box-shadow: 0 5px 20px rgba(46, 125, 50, 0.3);
            z-index: 2000;
            opacity: 0;
            visibility: hidden;
            transition: all 0.3s ease;
        }

        .toast.show {
            opacity: 1;
            visibility: visible;
            bottom: 40px;
        }

        /* Empty Cart Message */
        .empty-cart {
            text-align: center;
            color: #999;
            padding: 40px 20px;
        }

        .empty-cart i {
            font-size: 50px;
            margin-bottom: 15px;
            color: #c8e6c9;
        }

        /* No Results Message */
        .no-results {
            grid-column: 1 / -1;
            text-align: center;
            padding: 50px;
            background: white;
            border-radius: 15px;
            color: #2e7d32;
            font-size: 18px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }

        .no-results i {
            font-size: 50px;
            color: #81c784;
            margin-bottom: 15px;
        }

        /* Responsive */
        @media (max-width: 768px) {
            header {
                flex-direction: column;
                gap: 15px;
                padding: 15px;
            }
            
            .search-container {
                width: 100%;
            }
            
            .cart-sidebar {
                width: 100%;
                right: -100%;
            }
            
            .products-grid {
                grid-template-columns: repeat(2, 1fr);
                gap: 15px;
                padding: 10px;
            }
        }

        @media (max-width: 480px) {
            .products-grid {
                grid-template-columns: 1fr;
            }
            
            .product-card img {
                width: 120px;
                height: 120px;
            }
        }
    </style>
</head>
<body>

    <!-- Animated Background -->
    <div class="animated-bg"></div>

    <header>
        <div class="logo">
            <h1>💊 PharmaPlus</h1>
        </div>
        
        <!-- SEARCH -->
        <div class="search-container">
            <i class="fas fa-search search-icon"></i>
            <input type="text" id="searchInput" class="search-input" 
                   placeholder="Search medicines..." onkeyup="searchProducts()">
        </div>
        
        <!-- Cart Icon -->
        <div class="cart-icon-container" id="cartIcon">
            <i class="fas fa-shopping-cart"></i>
            <span class="cart-badge" id="cartBadge">0</span>
        </div>
    </header>

    <!-- Products Grid -->
    <div class="container">
        <h2 class="section-title">Our Medicines</h2>
        <div class="products-grid" id="productsGrid">
            <!-- Products will be loaded here dynamically -->
        </div>
    </div> 

    <!-- Cart Sidebar -->
    <div class="cart-sidebar" id="cartSidebar">
        <div class="cart-header">
            <h3><i class="fas fa-shopping-cart"></i> Your Cart</h3>
            <button class="close-cart" id="closeCart"><i class="fas fa-times"></i></button>
        </div>
        
        <div class="cart-items" id="cartItems">
            <!-- Cart items will appear here -->
        </div>
        
        <div class="cart-footer">
            <div class="cart-total">
                <span>Total:</span>
                <span class="total-amount" id="cartTotal">₹0</span>
            </div>
            <button class="checkout-btn" id="checkoutBtn" onclick="checkout()">
                <i class="fab fa-whatsapp"></i> Checkout
            </button>
        </div>
    </div>

    <!-- Overlay -->
    <div class="overlay" id="overlay"></div>

    <!-- Toast Notification -->
    <div class="toast" id="toast">Item added to cart!</div>

    <script>
        // Product Data
        const products = [
            { id: 1, name: "Dolo 650", price: 200, image: "dolo.jpg" },
            { id: 2, name: "Paracetamol 500 mg", price: 300, image: "dolo.jpg" },
            { id: 3, name: "Glimestar", price: 500, image:"dolo.jpg" },
            { id: 4, name: "Azithromycin", price: 450, image: "ghill.jpg" },
            { id: 5, name: "Vitamin C Tablets", price: 150, image: ".hilljpg" },
            { id: 6, name: "Calcium Supplements", price: 250, image: "hkk.jpg" },
         
        ];

        // Cart State
        let cart = [];

        // DOM Elements
        const cartIcon = document.getElementById('cartIcon');
        const cartSidebar = document.getElementById('cartSidebar');
        const overlay = document.getElementById('overlay');
        const closeCart = document.getElementById('closeCart');
        const cartItems = document.getElementById('cartItems');
        const cartBadge = document.getElementById('cartBadge');
        const cartTotal = document.getElementById('cartTotal');
        const productsGrid = document.getElementById('productsGrid');
        const toast = document.getElementById('toast');
        const searchInput = document.getElementById('searchInput');

        // Initialize products
        function loadProducts(filteredProducts = products) {
            productsGrid.innerHTML = '';
            
            if (filteredProducts.length === 0) {
                productsGrid.innerHTML = `
                    <div class="no-results">
                        <i class="fas fa-search"></i>
                        <h3>No medicines found</h3>
                        <p>Try searching with different keywords</p>
                    </div>
                `;
                return;
            }
            
            filteredProducts.forEach(product => {
                const card = document.createElement('div');
                card.className = 'product-card';
                card.setAttribute('onclick', `addToCart(${product.id})`);
                
                card.innerHTML = `
                    <img src="${product.image}" alt="${product.name}" onerror="this.src='https://via.placeholder.com/150?text=Medicine'">
                    <h3>${product.name}</h3>
                    <div class="price">₹${product.price}</div>
                    <button class="add-to-cart-btn" onclick="event.stopPropagation(); addToCart(${product.id})">
                        <i class="fas fa-cart-plus"></i>
                        Add to Cart
                    </button>
                `;
                
                productsGrid.appendChild(card);
            });
        }

        // SEARCH FUNCTION
        function searchProducts() {
            const searchTerm = searchInput.value.toLowerCase().trim();
            
            if (searchTerm === '') {
                loadProducts(products);
                return;
            }
            
            const filteredProducts = products.filter(product => 
                product.name.toLowerCase().includes(searchTerm)
            );
            
            loadProducts(filteredProducts);
            
            if (filteredProducts.length > 0) {
                showToast(`Found ${filteredProducts.length} medicines`);
            } else {
                showToast('No medicines found');
            }
        }

        // Add to cart
        function addToCart(productId) {
            const product = products.find(p => p.id === productId);
            const existingItem = cart.find(item => item.id === productId);
            
            if (existingItem) {
                existingItem.quantity++;
            } else {
                cart.push({
                    ...product,
                    quantity: 1
                });
            }
            
            updateCart();
            showToast(`✅ ${product.name} added to cart!`);
            
            // Animate cart icon
            cartIcon.style.animation = 'none';
            cartIcon.offsetHeight;
            cartIcon.style.animation = 'bounce 0.5s';
        }

        // Update cart display
        function updateCart() {
            const totalItems = cart.reduce((sum, item) => sum + item.quantity, 0);
            cartBadge.textContent = totalItems;
            
            if (cart.length === 0) {
                cartItems.innerHTML = `
                    <div class="empty-cart">
                        <i class="fas fa-shopping-cart"></i>
                        <p>Your cart is empty</p>
                        <small>Add medicines to get started</small>
                    </div>
                `;
            } else {
                cartItems.innerHTML = cart.map((item, index) => `
                    <div class="cart-item">
                        <div class="cart-item-info">
                            <div class="cart-item-name">${item.name}</div>
                            <div class="cart-item-price">₹${item.price}</div>
                        </div>
                        <div class="cart-item-actions">
                            <button class="quantity-btn" onclick="updateQuantity(${index}, -1)">−</button>
                            <span class="item-quantity">${item.quantity}</span>
                            <button class="quantity-btn" onclick="updateQuantity(${index}, 1)">+</button>
                            <button class="remove-item" onclick="removeFromCart(${index})">
                                <i class="fas fa-trash"></i>
                            </button>
                        </div>
                    </div>
                `).join('');
            }
            
            const total = cart.reduce((sum, item) => sum + (item.price * item.quantity), 0);
            cartTotal.textContent = `₹${total}`;
            
            localStorage.setItem('pharmaplus_cart', JSON.stringify(cart));
        }

        // Update quantity
        function updateQuantity(index, change) {
            if (cart[index].quantity + change > 0) {
                cart[index].quantity += change;
                showToast(`Quantity updated`);
            } else {
                const itemName = cart[index].name;
                cart.splice(index, 1);
                showToast(`${itemName} removed from cart`);
            }
            updateCart();
        }

        // Remove from cart
        function removeFromCart(index) {
            const itemName = cart[index].name;
            cart.splice(index, 1);
            updateCart();
            showToast(`❌ ${itemName} removed from cart`);
        }

        // Checkout via WhatsApp
        function checkout() {
            if (cart.length === 0) {
                showToast('Your cart is empty!');
                return;
            }
            
            let message = "🛑 *NEW ORDER - PharmaPlus* 🛑%0A%0A";
            let total = 0;
            
            cart.forEach(item => {
                message += `💊 *${item.name}*%0A`;
                message += `   ₹${item.price} x ${item.quantity} = ₹${item.price * item.quantity}%0A`;
                total += item.price * item.quantity;
            });
            
            message += `%0A💰 *TOTAL: ₹${total}*%0A`;
            message += `📍 *Delivery Address:* (Please share)%0A`;
            message += `📞 *Contact:* (Please share)%0A`;
            message += `%0A✨ *Thank you for ordering with PharmaPlus!*`;
            
            const phoneNumber = "8056512046";
            const url = `https://wa.me/${phoneNumber}?text=${message}`;
            
            window.open(url, '_blank');
            showToast('Opening WhatsApp...');
        }

        // Show toast message
        function showToast(message) {
            toast.textContent = message;
            toast.classList.add('show');
            
            setTimeout(() => {
                toast.classList.remove('show');
            }, 2000);
        }

        // Toggle cart sidebar
        function openCart() {
            cartSidebar.classList.add('open');
            overlay.classList.add('show');
            document.body.style.overflow = 'hidden';
        }

        function closeCartSidebar() {
            cartSidebar.classList.remove('open');
            overlay.classList.remove('show');
            document.body.style.overflow = 'auto';
        }

        // Load cart from localStorage
        function loadCartFromStorage() {
            const savedCart = localStorage.getItem('pharmaplus_cart');
            if (savedCart) {
                cart = JSON.parse(savedCart);
                updateCart();
            }
        }

        // Event Listeners
        cartIcon.addEventListener('click', openCart);
        closeCart.addEventListener('click', closeCartSidebar);
        overlay.addEventListener('click', closeCartSidebar);

        searchInput.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') {
                searchProducts();
            }
        });

        searchInput.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
                searchInput.value = '';
                loadProducts(products);
            }
        });

        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
                if (cartSidebar.classList.contains('open')) {
                    closeCartSidebar();
                }
                if (document.activeElement === searchInput) {
                    searchInput.value = '';
                    loadProducts(products);
                }
            }
        });

        // Initialize
        document.addEventListener('DOMContentLoaded', () => {
            loadProducts();
            loadCartFromStorage();
        });

        // Make functions globally available
        window.addToCart = addToCart;
        window.updateQuantity = updateQuantity;
        window.removeFromCart = removeFromCart;
        window.checkout = checkout;
        window.searchProducts = searchProducts;
        window.loadProducts = loadProducts;
    </script>
   
</body>
</html>
